# Environments
venv/
.venv/
env/
__pycache__/
.idea/
.DS_Store
.env

# Archive files and folders
archive/

# Excel lock files
~$*

# Heavy ML Models and folders
# NOTE: review_topic_model is a 484MB FILE (not a directory) — no trailing
# slash, or the pattern only matches directories and misses it entirely.
review_topic_model
models/embedding_model.pkl
*.pkl
!models/svm_final_model.pkl
!models/svm_final_label_encoder.pkl

# Local manual-export scratch folder (CI always uses the API, never this)
inputs/

# Databases and Data files
*.db
!data/metrics.db
*.csv
# NOTE: exceptions below need the full "data/" path — a bare filename like
# "!processed_ids.csv" only un-ignores that name in the repo ROOT, not
# inside data/, so it silently stays ignored. This exact bug is why
# data/processed_ids_raw.csv (needed for every daily run's dedup state)
# was never being committed.
!data/processed_ids.csv
!data/processed_ids_raw.csv
!data/tags.csv
!data/survey_cache.csv
!data/manuallytagged_complete.csv

# Weekly pipeline output exports — not tracked, regenerated every run
outputs/latest/*.xlsx
outputs/archive/

# Databases and Data files (xlsx)
*.xlsx
!data/master.xlsx

# Local pipeline logs — regenerated every run, not meant to live in git
logs/

# One-off local utility scripts — not part of the pipeline itself
fix_corrupted_ids.py